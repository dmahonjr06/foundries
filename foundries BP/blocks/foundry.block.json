                }
            },
            {
                "condition": "query.block_state('foundry:lava_level') == 13",
                "components": {
                    "minecraft:light_emission": 13
                }
            },
            {
                "condition": "query.block_state('foundry:lava_level') == 14",
                "components": {
                    "minecraft:light_emission": 14
                }
            },
            {
                "condition": "query.block_state('foundry:lava_level') == 15",
                "components": {
